{
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://notarium-backend.notarium-backend.workers.dev"
  },
  "devCommand": "npm run dev:frontend",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
