{
  "name": "notarium-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.js",
    "dev:wrangler": "wrangler dev",
    "start": "node dev-server.js",
    "build": "tsc",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 execute notarium-db --file=migrations/0001_allow_null_class.sql",
    "migrate:local": "wrangler d1 execute notarium-db-local --local --file=migrations/0001_allow_null_class.sql"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240604.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.114.15"
  }
}
