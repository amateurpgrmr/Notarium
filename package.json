{
  "name": "notarium-plus",
  "version": "1.0.0",
  "description": "Independent note-taking and study platform",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "dev": "npm run dev:frontend & npm run dev:backend",
    "build:frontend": "vite build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "deploy:frontend": "npm run build:frontend && vercel",
    "deploy:backend": "cd backend && npm run deploy",
    "deploy": "npm run deploy:backend && npm run deploy:frontend",
    "test": "echo 'Running tests...' && exit 0",
    "lint": "echo 'Linting...' && exit 0",
    "clean": "rm -rf node_modules backend/node_modules dist backend/dist"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
